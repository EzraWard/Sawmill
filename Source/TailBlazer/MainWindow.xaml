<Window
    x:Class="TailBlazer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls1="clr-namespace:TailBlazer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dockablz="clr-namespace:Dragablz.Dockablz;assembly=Dragablz"
    xmlns:dragablz="clr-namespace:Dragablz;assembly=Dragablz"
    xmlns:infrastucture="clr-namespace:TailBlazer.Infrastructure"
    xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:tailBlazer="clr-namespace:TailBlazer"
    xmlns:windowManagement="clr-namespace:TailBlazer.Views.WindowManagement"
    x:Name="Window"
    Title=""
    Width="950"
    Height="650"
    
    WindowStyle="None"
    d:DataContext="{d:DesignInstance windowManagement:WindowViewModel,
                                     IsDesignTimeCreatable=False}"
    infrastucture:WindowAssist.ApplicationClosing="{Binding WindowExiting}"

    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto"
    WindowStartupLocation="CenterScreen"
   
    mc:Ignorable="d">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="1"
            ResizeBorderThickness="4"
            GlassFrameThickness="-1"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>

            <infrastucture:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter" />

            <infrastucture:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <DataTemplate DataType="{x:Type infrastucture:FileHeader}">
                <TextBlock
                    Margin="6,2,2,2"
                    IsHitTestVisible="True"
                    Text="{Binding DisplayName}"
                    ToolTip="{Binding FullName}"
                    ToolTipService.ShowOnDisabled="True" />

            </DataTemplate>

            <DataTemplate DataType="{x:Type infrastucture:HeaderedView}">
                <ContentControl Content="{Binding Content}"  >
                    <ContentControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding DataContext.GeneralOptions.ScaleRatio.Value, ElementName=Window}" ScaleY="{Binding DataContext.GeneralOptions.ScaleRatio.Value, ElementName=Window}" />
                    </ContentControl.LayoutTransform>
                </ContentControl>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding
            Key="O"
            Command="{Binding OpenFileCommand}"
            Modifiers="Ctrl" />
        <KeyBinding Key="F8" Command="{Binding CollectMemoryCommand}" />

        <MouseBinding Command="{Binding ZoomInCommand}" Gesture="{x:Static infrastucture:MouseWheelGesture.ControlDown}" />
        <MouseBinding Command="{Binding ZoomOutCommand}" Gesture="{x:Static infrastucture:MouseWheelGesture.ControlUp}" />
    </Window.InputBindings>

    <AdornerDecorator>
        <materialDesign:DialogHost Identifier="{x:Static tailBlazer:DialogNames.EntireWindow}">

            <Grid x:Name="RootContent" infrastucture:DependencyObjectHook.Receiver="{Binding DropMonitor}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Height="40" Margin="10,0,0,0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <controls1:TailBlazerIcon Grid.Column="0" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,140,0" ClipToBounds="False">
                        <TabControl x:Name="TitleBarTabs" ClipToBounds="False"
                                    ItemsSource="{Binding Views}"
                                    SelectedItem="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom">
                            <TabControl.Resources>
                                <Style TargetType="TabPanel">
                                    <Setter Property="ClipToBounds" Value="False" />
                                    <Setter Property="Margin" Value="8,0,0,0" />
                                </Style>
                                <Style TargetType="{x:Type TabItem}">
                                    <EventSetter Event="PreviewMouseDown" Handler="TitleBarTabItem_PreviewMouseDown" />
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryHueDarkForegroundBrush}" />
                                    <Setter Property="Padding" Value="12,8,4,8" />
                                    <Setter Property="Panel.ZIndex" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Grid x:Name="Root" Margin="0,4,0,0" SnapsToDevicePixels="True">
                                                    <Border x:Name="TabBorder"
                                                            Background="Transparent"
                                                            CornerRadius="8,8,0,0"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center" />
                                                    </Border>
                                                    <Path x:Name="LeftCorner"
                                                          Data="M 0,8 A 8,8 0 0 0 8,0 L 8,8 Z"
                                                          Fill="#FF282828"
                                                          Width="8" Height="8"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Bottom"
                                                          Visibility="Collapsed">
                                                        <Path.RenderTransform>
                                                            <TranslateTransform X="-8" />
                                                        </Path.RenderTransform>
                                                    </Path>
                                                    <Path x:Name="RightCorner"
                                                          Data="M 8,8 A 8,8 0 0 1 0,0 L 0,8 Z"
                                                          Fill="#FF282828"
                                                          Width="8" Height="8"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Bottom"
                                                          Visibility="Collapsed">
                                                        <Path.RenderTransform>
                                                            <TranslateTransform X="8" />
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="TabBorder" Property="Background" Value="#FF282828" />
                                                        <Setter TargetName="LeftCorner" Property="Visibility" Value="Visible" />
                                                        <Setter TargetName="RightCorner" Property="Visibility" Value="Visible" />
                                                        <Setter TargetName="Root" Property="Margin" Value="0,0,0,0" />
                                                        <Setter Property="Panel.ZIndex" Value="1" />
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True" />
                                                            <Condition Property="IsSelected" Value="False" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="TabBorder" Property="Background" Value="#15FFFFFF" />
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.Resources>
                            <TabControl.Template>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid ClipToBounds="False">
                                        <TabPanel IsItemsHost="True" Margin="0,0,0,0" />
                                    </Grid>
                                </ControlTemplate>
                            </TabControl.Template>
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ContentPresenter Content="{Binding Header}" />
                                        <Button Margin="8,0,0,0"
                                                Width="20"
                                                Height="20"
                                                Padding="0"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"
                                                Command="{Binding DataContext.CloseViewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Close tab">
                                            <TextBlock Text="&#xE711;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                        </TabControl>
                        <Button Width="20"
                                Height="20"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                ToolTip="New tab"
                                Command="{Binding NewTabCommand}">
                            <TextBlock Text="&#xE710;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch">
                        <StackPanel.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueDarkForegroundBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Root" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="#22FFFFFF" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>
                        <Button Width="46"
                                Height="40"
                                Padding="0"
                                Click="MinimizeButton_Click">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="MaximizeRestoreButton"
                                Width="46"
                                Height="40"
                                Padding="0"
                                Click="MaximizeRestoreButton_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE922;" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                                <Setter Property="Text" Value="&#xE923;" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                        <Button Width="46"
                                Height="40"
                                Padding="0"
                                Click="CloseButton_Click">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C42B1C" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Background="Transparent" Visibility="{Binding IsShowingSettings, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">

                        <dockablz:Layout x:Name="Layout">
                            <Grid>
                                <!-- keep existing Dragablz control collapsed for compatibility; new TabControl used for UI -->
                                <dragablz:TabablzControl
                                    x:Name="InitialTabablzControl"
                                    Visibility="Collapsed"
                                    Background="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Path=Background}"
                                    ClosingItemCallback="{Binding ClosingTabItemHandler}"
                                    HeaderMemberPath="Header"
                                    IsTabStop="True"
                                    ItemsSource="{Binding Views}"
                                    SelectedItem="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ShowDefaultCloseButton="True"
                                    TextElement.Foreground="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Path=(TextElement.Foreground)}">

                                    <dragablz:TabablzControl.InterTabController>
                                        <dragablz:InterTabController InterTabClient="{Binding InterTabClient}" />
                                    </dragablz:TabablzControl.InterTabController>
                                </dragablz:TabablzControl>

                                <!-- Standard WPF TabControl - headers moved to titlebar, content shown here -->
                                <Grid x:Name="ContentFrameHost">
                                    <ContentControl x:Name="ContentFrameBorder" Content="{Binding Selected}" />
                                    <Border x:Name="SelectedTabTopGap"
                                            Height="1"
                                            VerticalAlignment="Top"
                                            HorizontalAlignment="Left"
                                            Background="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Background}"
                                            Visibility="Collapsed" />
                                </Grid>
                            </Grid>
                        </dockablz:Layout>

                        <StackPanel 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Orientation="Vertical"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,4"
                                HorizontalAlignment="Center"
                                FontSize="24"
                                Text="Drag files here" />
                            <controls1:FileIcon
                                Width="50"
                                Height="50"
                                BorderThickness="0"
                                Foreground="{DynamicResource  PrimaryHueMidBrush}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                FontSize="24"
                                Text="to open" />
                        </StackPanel>
                </Grid>

                    <!-- Full screen settings overlay -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SettingsMicaBrush}"
                            Visibility="{Binding IsShowingSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <Button Command="{Binding CloseSettingsCommand}" DockPanel.Dock="Top" HorizontalAlignment="Left"
                                    Width="40" Height="40" Margin="8" ToolTip="Back"
                                    BorderThickness="0" Background="Transparent"
                                    Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}">
                                <TextBlock Text="&#xE72B;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Button>
                            <ContentControl Content="{Binding FullScreenContent}" />
                        </DockPanel>
                    </Border>

                </Grid>
        </materialDesign:DialogHost>
    </AdornerDecorator>
</Window>

