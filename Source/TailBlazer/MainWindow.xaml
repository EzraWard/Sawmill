<Window
    x:Class="TailBlazer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls1="clr-namespace:TailBlazer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dockablz="clr-namespace:Dragablz.Dockablz;assembly=Dragablz"
    xmlns:dragablz="clr-namespace:Dragablz;assembly=Dragablz"
    xmlns:infrastucture="clr-namespace:TailBlazer.Infrastructure"
    xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:tailBlazer="clr-namespace:TailBlazer"
    xmlns:windowManagement="clr-namespace:TailBlazer.Views.WindowManagement"
    x:Name="Window"
    Title=""
    Width="950"
    Height="650"
    MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}"
    MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}"
    WindowStyle="None"
    d:DataContext="{d:DesignInstance windowManagement:WindowViewModel,
                                     IsDesignTimeCreatable=False}"
    infrastucture:WindowAssist.ApplicationClosing="{Binding WindowExiting}"

    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto"
    WindowStartupLocation="CenterScreen"
   
    mc:Ignorable="d">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            ResizeBorderThickness="4"
            GlassFrameThickness="-1"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>

            <infrastucture:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter" />

            <infrastucture:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <DataTemplate DataType="{x:Type infrastucture:FileHeader}">
                <TextBlock
                    Margin="6,2,2,2"
                    IsHitTestVisible="True"
                    Text="{Binding DisplayName}"
                    ToolTip="{Binding FullName}"
                    ToolTipService.ShowOnDisabled="True" />

            </DataTemplate>

            <DataTemplate DataType="{x:Type infrastucture:HeaderedView}">
                <ContentControl Content="{Binding Content}"  >
                    <ContentControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding DataContext.GeneralOptions.ScaleRatio.Value, ElementName=Window}" ScaleY="{Binding DataContext.GeneralOptions.ScaleRatio.Value, ElementName=Window}" />
                    </ContentControl.LayoutTransform>
                </ContentControl>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding
            Key="O"
            Command="{Binding OpenFileCommand}"
            Modifiers="Ctrl" />
        <KeyBinding Key="F8" Command="{Binding CollectMemoryCommand}" />

        <MouseBinding Command="{Binding ZoomInCommand}" Gesture="{x:Static infrastucture:MouseWheelGesture.ControlDown}" />
        <MouseBinding Command="{Binding ZoomOutCommand}" Gesture="{x:Static infrastucture:MouseWheelGesture.ControlUp}" />
    </Window.InputBindings>

    <AdornerDecorator>
        <materialDesign:DialogHost Identifier="{x:Static tailBlazer:DialogNames.EntireWindow}">

            <Grid infrastucture:DependencyObjectHook.Receiver="{Binding DropMonitor}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Height="40" Margin="10,0,0,0" Background="Transparent" shell:WindowChrome.IsHitTestVisibleInChrome="True" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <controls1:TailBlazerIcon Grid.Column="0" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,140,0">
                        <TabControl x:Name="TitleBarTabs"
                                    ItemsSource="{Binding Views}"
                                    SelectedItem="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Height="38"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TabControl.Resources>
                                <Style TargetType="{x:Type TabItem}">
                                    <Setter Property="MinWidth" Value="120" />
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryHueDarkForegroundBrush}" />
                                    <Setter Property="Background" Value="#1FFFFFFF" />
                                    <Setter Property="BorderBrush" Value="#33FFFFFF" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="Padding" Value="10,4" />
                                    <Setter Property="Margin" Value="0,3,8,3" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type TabItem}">
                                                <Border x:Name="TabRoot"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="7"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="TabRoot" Property="Background" Value="#44FFFFFF" />
                                                        <Setter TargetName="TabRoot" Property="BorderBrush" Value="#66FFFFFF" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="TabRoot" Property="Background" Value="#2AFFFFFF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.Resources>
                            <TabControl.Template>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid ClipToBounds="False">
                                        <TabPanel IsItemsHost="True" Margin="0,1,2,1" />
                                    </Grid>
                                </ControlTemplate>
                            </TabControl.Template>
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ContentPresenter Content="{Binding Header}" />
                                        <Button Margin="8,0,0,0"
                                                Width="16"
                                                Height="16"
                                                Padding="0"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                                Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"
                                                Command="{Binding DataContext.CloseViewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Close tab">
                                            <TextBlock Text="x" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                        </TabControl>
                        <Button Width="16"
                                Height="16"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                FontSize="10"
                                Padding="0"
                                Content="+"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="New tab"
                                Command="{Binding NewTabCommand}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Width="46"
                                Height="40"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                Click="MinimizeButton_Click">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <Button Width="46"
                                Height="40"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                Click="MaximizeRestoreButton_Click">
                            <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <Button Width="46"
                                Height="40"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                Click="CloseButton_Click">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,0,0,0" Panel.ZIndex="10"
                      Visibility="{Binding IsShowingSettings, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" TextElement.Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}">
                        <Button Width="40" Height="40" ToolTip="Settings" Margin="4,0,6,0" Command="{Binding OpenSettingsCommand}">
                            <controls1:SettingsIcon Width="16" Height="16" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Visibility="{Binding IsShowingSettings, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">

                        <dockablz:Layout x:Name="Layout">
                            <Grid>
                                <!-- keep existing Dragablz control collapsed for compatibility; new TabControl used for UI -->
                                <dragablz:TabablzControl
                                    x:Name="InitialTabablzControl"
                                    Visibility="Collapsed"
                                    Background="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Path=Background}"
                                    ClosingItemCallback="{Binding ClosingTabItemHandler}"
                                    HeaderMemberPath="Header"
                                    IsTabStop="True"
                                    ItemsSource="{Binding Views}"
                                    SelectedItem="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ShowDefaultCloseButton="True"
                                    TextElement.Foreground="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Path=(TextElement.Foreground)}">

                                    <dragablz:TabablzControl.InterTabController>
                                        <dragablz:InterTabController InterTabClient="{Binding InterTabClient}" />
                                    </dragablz:TabablzControl.InterTabController>
                                </dragablz:TabablzControl>

                                <!-- Standard WPF TabControl - headers moved to titlebar, content shown here -->
                                <ContentControl Content="{Binding Selected}" />
                            </Grid>
                        </dockablz:Layout>

                        <StackPanel 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Orientation="Vertical"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,4"
                                HorizontalAlignment="Center"
                                FontSize="26"
                                Text="Drag files here" />
                            <controls1:FileIcon
                                Width="50"
                                Height="50"
                                BorderThickness="0"
                                Foreground="{DynamicResource  PrimaryHueMidBrush}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                FontSize="26"
                                Text="to open" />
                        </StackPanel>
                </Grid>

                    <!-- Full screen settings overlay -->
                    <Border Grid.RowSpan="2"
                            Background="{DynamicResource SettingsMicaBrush}"
                            Visibility="{Binding IsShowingSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <Button Command="{Binding CloseSettingsCommand}" DockPanel.Dock="Top" HorizontalAlignment="Left"
                                    Width="36" Height="36" Margin="8" ToolTip="Back"
                                    BorderThickness="0" Background="Transparent"
                                    Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}">
                                <TextBlock Text="←" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <ContentControl Content="{Binding FullScreenContent}" />
                        </DockPanel>
                    </Border>

                </Grid>
        </materialDesign:DialogHost>
    </AdornerDecorator>
</Window>

