<controls1:TailBlazerWindow
    x:Class="TailBlazer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls1="clr-namespace:TailBlazer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dockablz="clr-namespace:Dragablz.Dockablz;assembly=Dragablz"
    xmlns:dragablz="clr-namespace:Dragablz;assembly=Dragablz"
    xmlns:infrastucture="clr-namespace:TailBlazer.Infrastructure"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:options="clr-namespace:TailBlazer.Views.Options"
    xmlns:recent="clr-namespace:TailBlazer.Views.Recent"
    xmlns:tailBlazer="clr-namespace:TailBlazer"
    xmlns:windowManagement="clr-namespace:TailBlazer.Views.WindowManagement"
    x:Name="Window"
    Title="Sawmill"
    Width="950"
    Height="650"
    d:DataContext="{d:DesignInstance windowManagement:WindowViewModel,
                                     IsDesignTimeCreatable=False}"
    infrastucture:WindowAssist.ApplicationClosing="{Binding WindowExiting}"

    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto"
    WindowStartupLocation="CenterScreen"
   
    mc:Ignorable="d">

    <!--Background="#FF37474F"
    FontFamily="{StaticResource MaterialDesignFont}"
    TextElement.FontSize="12"
    TextElement.FontWeight="Regular"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"-->

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ToggleButton.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Font.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Dragablz;component/Themes/materialdesign.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <infrastucture:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter" />

            <infrastucture:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <DataTemplate DataType="{x:Type infrastucture:FileHeader}">
                <TextBlock
                    Margin="6,2,2,2"
                    IsHitTestVisible="True"
                    Text="{Binding DisplayName}"
                    ToolTip="{Binding FullName}"
                    ToolTipService.ShowOnDisabled="True" />

            </DataTemplate>

            <DataTemplate DataType="{x:Type infrastucture:HeaderedView}">
                <ContentControl Content="{Binding Content}"  >
                    <ContentControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding DataContext.GeneralOptions.ScaleRatio.Value, ElementName=Window}" ScaleY="{Binding DataContext.GeneralOptions.ScaleRatio.Value, ElementName=Window}" />
                    </ContentControl.LayoutTransform>
                </ContentControl>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding
            Key="O"
            Command="{Binding OpenFileCommand}"
            Modifiers="Ctrl" />
        <KeyBinding Key="F8" Command="{Binding CollectMemoryCommand}" />

        <MouseBinding Command="{Binding ZoomInCommand}" Gesture="{x:Static infrastucture:MouseWheelGesture.ControlDown}" />
        <MouseBinding Command="{Binding ZoomOutCommand}" Gesture="{x:Static infrastucture:MouseWheelGesture.ControlUp}" />
    </Window.InputBindings>

    <AdornerDecorator>
        <materialDesign:DialogHost Identifier="{x:Static tailBlazer:DialogNames.EntireWindow}">

            <Grid infrastucture:DependencyObjectHook.Receiver="{Binding DropMonitor}">
                <Grid.RowDefinitions>
					<RowDefinition Height="32"/>
					<RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid VerticalAlignment="Top" HorizontalAlignment="Right" Grid.Row="0">
                    <StackPanel Orientation="Horizontal" TextElement.Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}">
                        <Button Width="40" Height="40" ToolTip="Settings" Margin="4,0,6,0" Command="{Binding OpenSettingsCommand}">
                            <controls1:SettingsIcon Width="16" Height="16" />
                        </Button>
                    </StackPanel>
                </Grid>
                <Grid VerticalAlignment="Top" HorizontalAlignment="Left" Grid.Row="0">
                    <StackPanel Orientation="Horizontal" >
                        <StackPanel.Resources>
                            <ResourceDictionary>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryHueDarkForegroundBrush}"/>

                                </Style>
                            </ResourceDictionary>
                        </StackPanel.Resources>

                        <Button Visibility="{Binding IsShowingSettings, Converter={StaticResource BooleanToVisibilityConverter}}" Command="{Binding CloseSettingsCommand}" Width="28" Height="28" Margin="0,0,6,0" ToolTip="Back">
                        <TextBlock Text="←" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>

                    <ToggleButton
                    x:Name="MenuToggleButton"
                    Width="24"
                    Height="24"
                    IsChecked="{Binding MenuIsOpen}"
                    Cursor="Hand"

                    Style="{StaticResource MaterialDesignHamburgerToggleButton}" 
                    Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"/>

                        <Button Command="{Binding OpenFileCommand}" ToolTip="Open file">
							<TextBlock Text="Open"/>
						</Button>
                    </StackPanel>
                </Grid>

                <materialDesign:DrawerHost IsLeftDrawerOpen="{Binding ElementName=MenuToggleButton, Path=IsChecked}" Grid.Row="2">
                    <materialDesign:DrawerHost.LeftDrawerContent>

                        <Grid TextElement.Foreground="{DynamicResource  MaterialDesignBody}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            
                            <recent:RecentFilesView
                                Grid.Row="1"
                                Margin="6,12,6,0"
                                DataContext="{Binding RecentFiles}" />
                        </Grid>

                    </materialDesign:DrawerHost.LeftDrawerContent>

                    <Grid>

                        <dockablz:Layout x:Name="Layout">
                            <Grid>
                                <!-- keep existing Dragablz control collapsed for compatibility; new TabControl used for UI -->
                                <dragablz:TabablzControl
                                    x:Name="InitialTabablzControl"
                                    Visibility="Collapsed"
                                    Background="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Path=Background}"
                                    ClosingItemCallback="{Binding ClosingTabItemHandler}"
                                    HeaderMemberPath="Header"
                                    IsTabStop="True"
                                    ItemsSource="{Binding Views}"
                                    SelectedItem="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ShowDefaultCloseButton="True"
                                    TextElement.Foreground="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Path=(TextElement.Foreground)}">

                                    <dragablz:TabablzControl.InterTabController>
                                        <dragablz:InterTabController InterTabClient="{Binding InterTabClient}" />
                                    </dragablz:TabablzControl.InterTabController>
                                </dragablz:TabablzControl>

                                <!-- Standard WPF TabControl replacing the visible tab UI -->
                                <TabControl x:Name="InitialTabControl"
                                            Background="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Path=Background}"
                                            ItemsSource="{Binding Views}"
                                            SelectedItem="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            TextElement.Foreground="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Path=(TextElement.Foreground)}">
                                    <TabControl.ItemContainerStyle>
                                        <Style TargetType="{x:Type TabItem}">
                                            <Setter Property="Header" Value="{Binding Header}" />
                                        </Style>
                                    </TabControl.ItemContainerStyle>
                                </TabControl>
                            </Grid>
                        </dockablz:Layout>

                        <StackPanel 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Orientation="Vertical"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,4"
                                HorizontalAlignment="Center"
                                FontSize="26"
                                Text="Drag files here" />
                            <controls1:FileIcon
                                Width="50"
                                Height="50"
                                BorderThickness="0"
                                Foreground="{DynamicResource  PrimaryHueMidBrush}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                FontSize="26"
                                Text="to open" />
                        </StackPanel>
                    </Grid>
                </materialDesign:DrawerHost>

                    <!-- Full screen settings overlay -->
                    <Border Grid.RowSpan="3"
                            Background="{DynamicResource SettingsMicaBrush}"
                            Visibility="{Binding IsShowingSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <!-- Back button in overlay header -->
                            <Button Command="{Binding CloseSettingsCommand}" DockPanel.Dock="Top" Width="36" Height="36" Margin="8">
                                <TextBlock Text="←" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <ContentControl Content="{Binding FullScreenContent}" />
                        </DockPanel>
                    </Border>

                </Grid>
        </materialDesign:DialogHost>
    </AdornerDecorator>
</controls1:TailBlazerWindow>
