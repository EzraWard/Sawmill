<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:TailBlazer.Controls"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════════════
         Design tokens (matching WCT SettingsControls)
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Card spacing -->
    <system:Double x:Key="SettingsCardSpacing">4</system:Double>

    <!-- SettingsCard dimensions -->
    <Thickness x:Key="SettingsCardPadding">16</Thickness>
    <system:Double x:Key="SettingsCardMinHeight">68</system:Double>
    <system:Double x:Key="SettingsCardDescriptionFontSize">12</system:Double>
    <system:Double x:Key="SettingsCardHeaderIconMaxSize">20</system:Double>
    <Thickness x:Key="SettingsCardHeaderIconMargin">2,0,20,0</Thickness>
    <Thickness x:Key="SettingsCardActionIconMargin">14,0,0,0</Thickness>
    <system:Double x:Key="SettingsCardActionIconMaxSize">13</system:Double>
    <system:Double x:Key="SettingsCardContentMinWidth">120</system:Double>

    <!-- SettingsExpander dimensions -->
    <Thickness x:Key="SettingsExpanderHeaderPadding">16,16,4,16</Thickness>
    <Thickness x:Key="SettingsExpanderItemPadding">58,8,44,8</Thickness>
    <Thickness x:Key="SettingsExpanderItemBorderThickness">0,1,0,0</Thickness>
    <system:Double x:Key="SettingsExpanderChevronButtonSize">32</system:Double>

    <!-- Card colors (dark theme) -->
    <SolidColorBrush x:Key="SettingsCardBackgroundBrush" Color="#0DFFFFFF" />
    <SolidColorBrush x:Key="SettingsCardBackgroundPointerOverBrush" Color="#15FFFFFF" />
    <SolidColorBrush x:Key="SettingsCardBackgroundPressedBrush" Color="#08FFFFFF" />
    <SolidColorBrush x:Key="SettingsCardBackgroundDisabledBrush" Color="#05FFFFFF" />
    <SolidColorBrush x:Key="SettingsCardStrokeBrush" Color="#19FFFFFF" />
    <SolidColorBrush x:Key="SettingsCardStrokePointerOverBrush" Color="#24FFFFFF" />
    <SolidColorBrush x:Key="SettingsCardDescriptionForegroundBrush" Color="#9EFFFFFF" />

    <!-- Section header style -->
    <Style x:Key="SettingsSectionHeaderTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="1,30,0,6" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
    </Style>


    <!-- ═══════════════════════════════════════════════════════════════════
         SettingsCard Template
         Layout: [HeaderIcon] [Header / Description] [Content] [ActionIcon]
         ═══════════════════════════════════════════════════════════════════ -->
    <Style TargetType="controls:SettingsCard">
        <Setter Property="Background" Value="{StaticResource SettingsCardBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
        <Setter Property="BorderBrush" Value="{StaticResource SettingsCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="{StaticResource SettingsCardMinHeight}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Padding" Value="{StaticResource SettingsCardPadding}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:SettingsCard">
                    <Border x:Name="PART_RootBorder"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalAlignment}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Col 0: HeaderIcon -->
                                <ColumnDefinition Width="Auto" />
                                <!-- Col 1: Header + Description -->
                                <ColumnDefinition Width="*" />
                                <!-- Col 2: Content (right-aligned) -->
                                <ColumnDefinition Width="Auto" />
                                <!-- Col 3: ActionIcon -->
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Header Icon -->
                            <Viewbox x:Name="PART_HeaderIconPresenterHolder"
                                     Grid.Column="0"
                                     MaxWidth="{StaticResource SettingsCardHeaderIconMaxSize}"
                                     MaxHeight="{StaticResource SettingsCardHeaderIconMaxSize}"
                                     Margin="{StaticResource SettingsCardHeaderIconMargin}"
                                     VerticalAlignment="Center">
                                <ContentPresenter Content="{TemplateBinding HeaderIcon}" />
                            </Viewbox>

                            <!-- Header + Description -->
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <ContentPresenter x:Name="PART_HeaderPresenter"
                                                  Content="{TemplateBinding Header}"
                                                  TextElement.FontSize="14" />
                                <ContentPresenter x:Name="PART_DescriptionPresenter"
                                                  Content="{TemplateBinding Description}"
                                                  Margin="0,2,0,0"
                                                  TextElement.FontSize="{StaticResource SettingsCardDescriptionFontSize}"
                                                  TextElement.Foreground="{StaticResource SettingsCardDescriptionForegroundBrush}" />
                            </StackPanel>

                            <!-- Content (right-aligned control) -->
                            <ContentPresenter x:Name="PART_ContentPresenter"
                                              Grid.Column="2"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              Margin="16,0,0,0" />

                            <!-- Action Icon (visible when IsClickEnabled) -->
                            <Viewbox x:Name="PART_ActionIconPresenterHolder"
                                     Grid.Column="3"
                                     MaxWidth="{StaticResource SettingsCardActionIconMaxSize}"
                                     MaxHeight="{StaticResource SettingsCardActionIconMaxSize}"
                                     Margin="{StaticResource SettingsCardActionIconMargin}"
                                     VerticalAlignment="Center"
                                     Visibility="Collapsed">
                                <TextBlock Text="&#xE974;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Opacity="0.6" />
                            </Viewbox>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hide icon holder when no icon -->
                        <Trigger Property="HeaderIcon" Value="{x:Null}">
                            <Setter TargetName="PART_HeaderIconPresenterHolder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- Hide description when null/empty -->
                        <Trigger Property="Description" Value="{x:Null}">
                            <Setter TargetName="PART_DescriptionPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- Hide header when null -->
                        <Trigger Property="Header" Value="{x:Null}">
                            <Setter TargetName="PART_HeaderPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- Hide content when null -->
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter TargetName="PART_ContentPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- Show action icon when clickable -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsClickEnabled" Value="True" />
                                <Condition Property="IsActionIconVisible" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_ActionIconPresenterHolder" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <!-- Pointer over -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_RootBorder" Property="Background"
                                    Value="{StaticResource SettingsCardBackgroundPointerOverBrush}" />
                            <Setter TargetName="PART_RootBorder" Property="BorderBrush"
                                    Value="{StaticResource SettingsCardStrokePointerOverBrush}" />
                        </Trigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_RootBorder" Property="Background"
                                    Value="{StaticResource SettingsCardBackgroundDisabledBrush}" />
                            <Setter TargetName="PART_RootBorder" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SettingsCard variant for expander child items (flat corners, top border only) -->
    <Style x:Key="SettingsExpanderItemStyle" TargetType="controls:SettingsCard"
           BasedOn="{StaticResource {x:Type controls:SettingsCard}}">
        <Setter Property="MinHeight" Value="52" />
        <Setter Property="Padding" Value="{StaticResource SettingsExpanderItemPadding}" />
        <Setter Property="BorderThickness" Value="{StaticResource SettingsExpanderItemBorderThickness}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:SettingsCard">
                    <Border x:Name="PART_RootBorder"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource SettingsCardStrokeBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Viewbox x:Name="PART_HeaderIconPresenterHolder"
                                     Grid.Column="0"
                                     MaxWidth="{StaticResource SettingsCardHeaderIconMaxSize}"
                                     MaxHeight="{StaticResource SettingsCardHeaderIconMaxSize}"
                                     Margin="0,0,14,0"
                                     VerticalAlignment="Center">
                                <ContentPresenter Content="{TemplateBinding HeaderIcon}" />
                            </Viewbox>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <ContentPresenter x:Name="PART_HeaderPresenter"
                                                  Content="{TemplateBinding Header}"
                                                  TextElement.FontSize="14" />
                                <ContentPresenter x:Name="PART_DescriptionPresenter"
                                                  Content="{TemplateBinding Description}"
                                                  Margin="0,2,0,0"
                                                  TextElement.FontSize="{StaticResource SettingsCardDescriptionFontSize}"
                                                  TextElement.Foreground="{StaticResource SettingsCardDescriptionForegroundBrush}" />
                            </StackPanel>

                            <ContentPresenter Grid.Column="2"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              Margin="16,0,0,0" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HeaderIcon" Value="{x:Null}">
                            <Setter TargetName="PART_HeaderIconPresenterHolder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Description" Value="{x:Null}">
                            <Setter TargetName="PART_DescriptionPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Header" Value="{x:Null}">
                            <Setter TargetName="PART_HeaderPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_RootBorder" Property="Background"
                                    Value="{StaticResource SettingsCardBackgroundPointerOverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_RootBorder" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ═══════════════════════════════════════════════════════════════════
         SettingsExpander Template
         A collapsible container hosting a SettingsCard header + child items
         ═══════════════════════════════════════════════════════════════════ -->
    <Style TargetType="controls:SettingsExpander">
        <Setter Property="Background" Value="{StaticResource SettingsCardBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
        <Setter Property="BorderBrush" Value="{StaticResource SettingsCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="{StaticResource SettingsCardMinHeight}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:SettingsExpander">
                    <Border x:Name="PART_RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True"
                            ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <!-- Row 0: Header (toggle) -->
                                <RowDefinition Height="Auto" />
                                <!-- Row 1: Expanded content -->
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Header row: clickable toggle -->
                            <ToggleButton x:Name="PART_ExpanderToggle"
                                          Grid.Row="0"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalContentAlignment="Stretch"
                                          Cursor="Hand"
                                          Focusable="True"
                                          OverridesDefaultStyle="True">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ToggleBorder"
                                                Background="{TemplateBinding Background}"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Stretch" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background"
                                                        Value="{StaticResource SettingsCardBackgroundPointerOverBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>

                                <!-- Header content grid -->
                                <Grid MinHeight="{StaticResource SettingsCardMinHeight}"
                                      Margin="{StaticResource SettingsExpanderHeaderPadding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Header icon -->
                                    <Viewbox x:Name="PART_HeaderIconHolder"
                                             Grid.Column="0"
                                             MaxWidth="{StaticResource SettingsCardHeaderIconMaxSize}"
                                             MaxHeight="{StaticResource SettingsCardHeaderIconMaxSize}"
                                             Margin="{StaticResource SettingsCardHeaderIconMargin}"
                                             VerticalAlignment="Center">
                                        <ContentPresenter Content="{TemplateBinding HeaderIcon}" />
                                    </Viewbox>

                                    <!-- Header + Description -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <ContentPresenter x:Name="PART_HeaderPresenter"
                                                          Content="{TemplateBinding Header}"
                                                          TextElement.FontSize="14" />
                                        <ContentPresenter x:Name="PART_DescriptionPresenter"
                                                          Content="{TemplateBinding Description}"
                                                          Margin="0,2,0,0"
                                                          TextElement.FontSize="{StaticResource SettingsCardDescriptionFontSize}"
                                                          TextElement.Foreground="{StaticResource SettingsCardDescriptionForegroundBrush}" />
                                    </StackPanel>

                                    <!-- Content (right side of header) -->
                                    <ContentPresenter x:Name="PART_ContentPresenter"
                                                      Grid.Column="2"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding Content}"
                                                      Margin="16,0,0,0" />

                                    <!-- Chevron button -->
                                    <Border Grid.Column="3"
                                            Width="{StaticResource SettingsExpanderChevronButtonSize}"
                                            Height="{StaticResource SettingsExpanderChevronButtonSize}"
                                            Margin="4,0,8,0"
                                            VerticalAlignment="Center">
                                        <TextBlock x:Name="ChevronGlyph"
                                                   Text="&#xE70D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MaterialDesignBody}"
                                                   Opacity="0.6"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform x:Name="ChevronRotation" Angle="0" />
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </ToggleButton>

                            <!-- Expanded items panel -->
                            <StackPanel x:Name="PART_ItemsPanel"
                                        Grid.Row="1"
                                        Visibility="Collapsed">
                                <ItemsControl ItemsSource="{TemplateBinding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ContentPresenter Content="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ContentPresenter Content="{TemplateBinding ItemsFooter}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hide icon when null -->
                        <Trigger Property="HeaderIcon" Value="{x:Null}">
                            <Setter TargetName="PART_HeaderIconHolder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- Hide description when null -->
                        <Trigger Property="Description" Value="{x:Null}">
                            <Setter TargetName="PART_DescriptionPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- Hide content when null -->
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter TargetName="PART_ContentPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- Expanded state -->
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="PART_ItemsPanel" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ChevronGlyph" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="180" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <!-- Hover on root -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_RootBorder" Property="BorderBrush"
                                    Value="{StaticResource SettingsCardStrokePointerOverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
