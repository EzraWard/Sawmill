<UserControl x:Class="TailBlazer.Views.Options.GeneralOptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:options="clr-namespace:TailBlazer.Views.Options"
             xmlns:controls="clr-namespace:TailBlazer.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance options:GeneralOptionsViewModel, IsDesignTimeCreatable=False}">

    <StackPanel Margin="0,2,0,0">

        <!-- ════════════════ Look and Feel ════════════════ -->
        <TextBlock Text="Look and Feel"
                   Style="{DynamicResource SettingsSectionHeaderTextBlockStyle}" />

        <controls:SettingsCard Header="Theme"
                               Description="Set the color scheme you prefer"
                               Visibility="Collapsed">
            <controls:SettingsCard.HeaderIcon>
                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </controls:SettingsCard.HeaderIcon>
            <ComboBox ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding SelectedTheme}"
                      MinWidth="120" />
        </controls:SettingsCard>

        <controls:SettingsCard Header="Zoom"
                               Description="Adjust the text size">
            <controls:SettingsCard.HeaderIcon>
                <TextBlock Text="&#xE8E9;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </controls:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Slider Minimum="80" Maximum="200"
                        Style="{StaticResource {x:Type Slider}}"
                        SmallChange="5" LargeChange="5"
                        Width="180"
                        VerticalAlignment="Center"
                        Value="{Binding Scale}" />
                <TextBlock Text="{Binding ScaleText.Value}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           MinWidth="48" />
            </StackPanel>
        </controls:SettingsCard>

        <controls:SettingsCard Header="Highlight tail"
                               Description="Flash new lines as they appear">
            <controls:SettingsCard.HeaderIcon>
                <TextBlock Text="&#xE7E6;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </controls:SettingsCard.HeaderIcon>
            <CheckBox IsChecked="{Binding HighlightTail}" />
        </controls:SettingsCard>

        <controls:SettingsCard Header="Open recent files on startup"
                               Description="Automatically reopen previously viewed files">
            <controls:SettingsCard.HeaderIcon>
                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </controls:SettingsCard.HeaderIcon>
            <CheckBox IsChecked="{Binding OpenRecentOnStartup}" />
        </controls:SettingsCard>

        <controls:SettingsCard Header="Show line numbers"
                               Description="Display line numbers alongside log content">
            <controls:SettingsCard.HeaderIcon>
                <TextBlock Text="&#xE8A4;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </controls:SettingsCard.HeaderIcon>
            <CheckBox IsChecked="{Binding ShowLineNumbers}" />
        </controls:SettingsCard>

        <!-- ════════════════ Performance ════════════════ -->
        <TextBlock Text="Performance"
                   Style="{DynamicResource SettingsSectionHeaderTextBlockStyle}" />

        <controls:SettingsCard Header="Rate this computer"
                               Description="Reduce for lower CPU usage">
            <controls:SettingsCard.HeaderIcon>
                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            </controls:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Slider Style="{StaticResource {x:Type Slider}}"
                        VerticalAlignment="Center"
                        Minimum="1" Maximum="5"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Width="140"
                        Value="{Binding Rating, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <StackPanel Orientation="Horizontal"
                            Margin="8,0,0,0"
                            Visibility="{Binding RequiresRestart.Value, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Command="{Binding RestartCommand}"
                            Padding="8,3"
                            Style="{DynamicResource MaterialDesignFlatButton}">
                        <TextBlock Text="Restart" FontSize="12" />
                    </Button>
                    <TextBlock Text="Restart to apply"
                               Margin="4,0,0,0"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </controls:SettingsCard>

    </StackPanel>
</UserControl>
