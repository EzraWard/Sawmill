<UserControl x:Class="TailBlazer.Views.Options.GeneralOptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:options="clr-namespace:TailBlazer.Views.Options"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance options:GeneralOptionsViewModel, IsDesignTimeCreatable=False}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>


        <TextBlock  Text="Look And Feel" FontSize="16" FontWeight="SemiBold"/>
        <Grid Grid.Row="1" Margin="8">

            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                      Content="Dark Theme"
                      VerticalAlignment="Center"
                      Margin="4 6 4 6"
                      IsChecked="{Binding UseDarkTheme}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Zoom"
                       VerticalAlignment="Center" Margin="4 6 4 6" />
            <Slider Grid.Row="1"
                    Grid.Column="1" Minimum="80" Maximum="200"
                    SmallChange="5"
                    LargeChange="5"
                    Width="150"
                    Margin="6 6 4 6"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Value="{Binding Scale}" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ScaleText.Value}"
                       VerticalAlignment="Center" Margin="4 6 4 6" />

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                       Margin="4 6 4 6">Highlight Tail?</TextBlock>
            <CheckBox Grid.Row="2" Grid.Column="1"
                      VerticalAlignment="Center"
                      Margin="4"
                      IsChecked="{Binding  HighlightTail}" />

            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"
                       Margin="4 6 4 6">Open Recent Files On Startup?</TextBlock>
            <CheckBox Grid.Row="3" Grid.Column="1"
                      VerticalAlignment="Center"
                      Margin="4"
                      IsChecked="{Binding  OpenRecentOnStartup}" />

            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                       Margin="4 6 4 6">Show Line Numbers?</TextBlock>
            <CheckBox Grid.Row="4" Grid.Column="1"
                      VerticalAlignment="Center"
                      Margin="4"
                      IsChecked="{Binding ShowLineNumbers}" />

        </Grid>

        <TextBlock
            Margin="0 8 0 0"
            Text="Performance" Grid.Row="2" FontSize="16" FontWeight="SemiBold" />

        <Grid Grid.Row="3" Margin="8 8 8 0" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Rate this computer" VerticalAlignment="Center" />
            <Slider Margin="6 0 0 0"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Minimum="1" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"
                    Value="{Binding Rating, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Margin="6 0 0 0" Grid.Column="2" Text="(Reduce for lower CPU usage)" VerticalAlignment="Center" />

            <StackPanel Grid.Column="3"
                        Margin="6 2 4 4"
                        Visibility="{Binding RequiresRestart.Value, Converter={StaticResource BooleanToVisibilityConverter}}"
                        HorizontalAlignment="Left" Orientation="Horizontal">

                <Button Command="{Binding RestartCommand}"
                        HorizontalAlignment="Left"
                        Margin="0 -2 0 0"
                        Padding="4 2">
                    <TextBlock Text="Restart" FontSize="12" />
                </Button>

                <TextBlock Text="Restart to apply"
                           Margin="4 0 0 0"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>

        </Grid>


        <Grid Grid.Row="5" Margin="8">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>


            <TextBlock Grid.Row="1" Grid.Column="0"
                       Visibility="Collapsed"
                       VerticalAlignment="Center">
                Highlight Duration
            </TextBlock>

            <Slider Grid.Row="1" Grid.Column="1" Minimum="0.25" Maximum="10"
                    Margin="6 4 4 4"

                    Visibility="Collapsed"
                    Width="200"
                    SmallChange="0.25"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    LargeChange="1"
                    Value="{Binding HighlightDuration}" />

            <TextBlock Grid.Row="1" Grid.Column="2"
                       Visibility="Collapsed"
                       VerticalAlignment="Center"
                       Text="{Binding HighlightDurationText.Value}" />

        </Grid>

    </Grid>
</UserControl>
